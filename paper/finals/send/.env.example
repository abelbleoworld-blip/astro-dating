# SMTP creds for a@aadmitrieff.com (Timeweb Mail)
# Get from: Timeweb panel → Mail → SMTP settings
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=a@aadmitrieff.com
SMTP_PASS=

# Sender display name
SENDER_NAME=Alexander A. Dmitriev

# Path to PDF attachment (relative to send.js)
ATTACHMENT_PATH=../../SOL1-Publication.pdf

# Throttle between sends (ms) — Timeweb spam-filter friendly
SEND_DELAY_MS=60000

# Where to write send.jsonl audit log
LOG_PATH=../sent.jsonl

# Dry-run by default; explicit --send required to actually transmit
DEFAULT_DRY_RUN=true
